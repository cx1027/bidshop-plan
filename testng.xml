<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Bidshop Automation Suite" parallel="tests" thread-count="1">
    <listeners>
        <listener class-name="com.bidshop.listeners.TestListener"/>
    </listeners>

    <test name="HomePage Tests" preserve-order="true">
        <classes>
            <class name="com.bidshop.tests.HomePageTest"/>
        </classes>
    </test>

    <test name="LoginPage Tests" preserve-order="true">
        <classes>
            <class name="com.bidshop.tests.LoginPageTest"/>
        </classes>
    </test>

    <test name="RegisterPage Tests" preserve-order="true">
        <classes>
            <class name="com.bidshop.tests.RegisterPageTest"/>
        </classes>
    </test>

    <test name="CartPage Tests" preserve-order="true">
        <classes>
            <class name="com.bidshop.tests.CartPageTest"/>
        </classes>
    </test>

    <test name="CheckoutPage Tests" preserve-order="true">
        <classes>
            <class name="com.bidshop.tests.CheckoutPageTest"/>
        </classes>
    </test>
</suite>
